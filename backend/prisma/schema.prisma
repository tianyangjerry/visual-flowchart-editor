generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum NodeStatus {
  not_started
  active
  completed
  blocked
}

model WorkflowDefinition {
  id             String                @id @default(cuid())
  name           String
  description    String                @default("")
  schemaVersion  Int                   @default(2)
  definition     Json
  triggerMap     Json?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  runtimes       WorkflowRuntime[]
}

model WorkflowRuntime {
  id              String                 @id @default(cuid())
  workflowId      String
  status          NodeStatus              @default(not_started)
  currentNodeId   String?
  runtimeState    Json
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  workflow        WorkflowDefinition      @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  events          WorkflowRuntimeEvent[]
}

model WorkflowRuntimeEvent {
  id            String          @id @default(cuid())
  runtimeId     String
  moduleCode    String
  eventType     String
  payload       Json
  result        Json?
  createdAt     DateTime        @default(now())
  runtime       WorkflowRuntime @relation(fields: [runtimeId], references: [id], onDelete: Cascade)
}
